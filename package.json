    "adm-zip": "^0.5.17",
    "axios": "^1.16.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fengari": "^0.1.5",
    "fengari-interop": "^0.1.4",
    "fzstd": "^0.1.1",
    "luamin": "^1.0.4",
